# =============================================================================
# InstallLEO Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control
#
# For Vercel deployment, add these in:
# Project Settings > Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Email Notifications via Resend
# -----------------------------------------------------------------------------

# Your Resend API key for sending email notifications
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to receive lead notifications
# This is where new lead alerts will be sent
NOTIFICATION_EMAIL=leads@installleo.com

# (Optional) Custom sender email address
# Must be verified in Resend dashboard
# Default: "InstallLEO <noreply@installleo.com>"
FROM_EMAIL=InstallLEO <noreply@installleo.com>

# -----------------------------------------------------------------------------
# REQUIRED - Site Configuration
# -----------------------------------------------------------------------------

# Your production site URL (no trailing slash)
# Used for canonical URLs, sitemap, and OpenGraph
NEXT_PUBLIC_SITE_URL=https://installleo.com

# -----------------------------------------------------------------------------
# ANALYTICS - Google Analytics 4
# -----------------------------------------------------------------------------

# Google Analytics 4 Measurement ID
# Get from: Google Analytics > Admin > Data Streams > Web
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# -----------------------------------------------------------------------------
# ANALYTICS - Meta (Facebook) Pixel
# -----------------------------------------------------------------------------

# Meta Pixel ID for Facebook/Instagram ads tracking
# Get from: Meta Events Manager > Data Sources > Pixel
# Format: 15-16 digit number
NEXT_PUBLIC_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# OPTIONAL - Additional Tracking
# -----------------------------------------------------------------------------

# Google Ads Conversion ID (for conversion tracking)
# Format: AW-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Tag Manager Container ID
# Format: GTM-XXXXXXX
# NEXT_PUBLIC_GTM_ID=

# Microsoft/Bing UET Tag ID
# NEXT_PUBLIC_BING_UET_ID=

# LinkedIn Insight Tag Partner ID
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# -----------------------------------------------------------------------------
# OPTIONAL - Search Console Verification
# -----------------------------------------------------------------------------

# Google Search Console verification code
# Get from: Search Console > Settings > Ownership verification > HTML tag
# GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification code
# BING_SITE_VERIFICATION=

# -----------------------------------------------------------------------------
# OPTIONAL - CRM & Integrations
# -----------------------------------------------------------------------------

# Webhook URL for lead notifications (Zapier, Make, etc.)
# WEBHOOK_URL=

# HubSpot API key for CRM integration
# HUBSPOT_API_KEY=

# Slack webhook for team notifications
# SLACK_WEBHOOK_URL=

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# 
# Before deploying to production:
#
# [ ] RESEND_API_KEY is set and verified
# [ ] NOTIFICATION_EMAIL is correct
# [ ] NEXT_PUBLIC_SITE_URL matches your domain
# [ ] Domain DNS is configured in Vercel
# [ ] SSL certificate is provisioned
# [ ] GA4 property is created and ID is set
# [ ] Meta Pixel is created and ID is set
# [ ] Google Search Console is verified
# [ ] Bing Webmaster Tools is verified
#
# =============================================================================
